{
  "name": "sws-attention-protocol",
  "version": "1.0.0",
  "description": "SWS Proof of Attention Protocol — Cryptographic verification of genuine human attention",
  "main": "src/sdk/attention-protocol.js",
  "scripts": {
    "start": "node server/index.js",
    "test": "node --max-old-space-size=4096 node_modules/.bin/jest --verbose --forceExit",
    "test:core": "jest tests/sdk-core.test.js --verbose",
    "test:algorithms": "jest tests/behavioral-algorithms.test.js --verbose",
    "test:ga4": "jest tests/ga4-comparison.test.js --verbose",
    "test:bots": "jest tests/bot-harness.test.js --verbose --forceExit",
    "test:api": "jest tests/api-server.test.js --verbose --forceExit",
    "test:flow": "node scripts/test-cme-flow-narrative.js --variant=all",
    "server": "node server/index.js",
    "serve": "npx http-server public -p 8080 -c-1",
    "dashboard": "npx http-server src/dashboard -p 3000 -c-1",
    "proof": "node proof/run-proofs.js",
    "proof:json": "node proof/run-proofs.js --json",
    "proof:upload": "node proof/upload-to-firestore.js",
    "proof:upload:dry": "node proof/upload-to-firestore.js --dry-run",
    "proof:gallery": "npx http-server proof -p 4000 -c-1"
  },
  "author": "SWS Strategic Media LLC",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "jest": "^30.3.0",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "dependencies": {
    "@fingerprintjs/botd": "^2.0.0",
    "@peculiar/asn1-cms": "^2.6.1",
    "@peculiar/asn1-schema": "^2.6.0",
    "@peculiar/asn1-tsp": "^2.6.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "javascript-opentimestamps": "^0.4.5",
    "merkletreejs": "^0.6.0",
    "uuid": "^13.0.0"
  }
}

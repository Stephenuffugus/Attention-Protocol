{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      "run-proofs.js",
      "upload-to-firestore.js",
      "firebase-config.js"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/gallery.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
